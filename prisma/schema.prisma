// VibeCareer AI — Prisma Schema
// Database: PostgreSQL (Neon Serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH MODELS (NextAuth.js v4 compatible)
// ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?   // hashed via bcryptjs
  role            UserRole  @default(JOB_SEEKER)
  bio             String?
  location        String?
  targetRole      String?
  experienceLevel String?
  careerScore     Int       @default(0)
  onboarded       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  resumes         Resume[]
  coverLetters    CoverLetter[]
  applications    Application[]
  savedJobs       SavedJob[]
  coachSessions   CoachSession[]
  interviewSessions InterviewSession[]
}

enum UserRole {
  JOB_SEEKER
  STUDENT
  CAREER_SWITCHER
  PROFESSIONAL
}

// ─────────────────────────────────────────
// RESUME
// ─────────────────────────────────────────

model Resume {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("My Resume")
  template  String   @default("modern")
  content   Json     // ResumeContent type (see types/)
  atsScore  Int?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// COVER LETTER
// ─────────────────────────────────────────

model CoverLetter {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("Cover Letter")
  company     String
  role        String
  content     String   @db.Text
  tone        String   @default("professional")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// JOB APPLICATION TRACKER
// ─────────────────────────────────────────

model Application {
  id          String            @id @default(cuid())
  userId      String
  company     String
  role        String
  status      ApplicationStatus @default(WISHLIST)
  appliedAt   DateTime?
  notes       String?           @db.Text
  interviewAt DateTime?
  salary      String?
  jobUrl      String?
  location    String?
  remote      Boolean           @default(false)
  matchScore  Int?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

// ─────────────────────────────────────────
// SAVED JOBS
// ─────────────────────────────────────────

model SavedJob {
  id          String   @id @default(cuid())
  userId      String
  externalId  String
  title       String
  company     String
  location    String?
  salary      String?
  description String?  @db.Text
  jobUrl      String
  remote      Boolean  @default(false)
  matchScore  Int?
  savedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
}

// ─────────────────────────────────────────
// AI COACH SESSIONS
// ─────────────────────────────────────────

model CoachSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("Career Coaching Session")
  messages  Json          // Array of { role, content, timestamp }
  scenario  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MOCK INTERVIEW SESSIONS
// ─────────────────────────────────────────

model InterviewSession {
  id          String          @id @default(cuid())
  userId      String
  role        String
  type        InterviewType   @default(BEHAVIORAL)
  questions   Json            // Array of { question, answer, score, feedback }
  overallScore Int?
  feedback    String?         @db.Text
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum InterviewType {
  BEHAVIORAL
  TECHNICAL
  HR
  MIXED
}
